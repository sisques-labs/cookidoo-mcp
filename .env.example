# ---------------------------------------------------------------------------
# Cookidoo MCP server configuration
# Copy this file to `.env` and fill in your Cookidoo credentials.
# ---------------------------------------------------------------------------

# HTTP port the MCP server listens on (optional, defaults to 3000).
PORT=3000

# Set to "true" to log the full OAuth2 login flow (each redirect hop and the
# Set-Cookie outcomes). Useful to debug authentication problems.
COOKIDOO_DEBUG=false

# Cookidoo account credentials (required).
COOKIDOO_EMAIL=your@email.com
COOKIDOO_PASSWORD=your-password

# Optional path to persist the session across restarts. When set, the server
# restores the login from this file on startup and rewrites it after each
# successful login, so it doesn't have to log in again on every restart. Leave
# unset to keep the session only in memory.
# COOKIDOO_COOKIE_FILE=./.cookidoo-session.json

# Localization (optional). Defaults to Spanish Cookidoo (Spain).
# Override all three together to target another market.
# Examples:
#   es / es-ES / https://cookidoo.es/foundation/es-ES
#   ch / de-CH / https://cookidoo.ch/foundation/de-CH
#   gb / en-GB / https://cookidoo.co.uk/foundation/en-GB
COOKIDOO_COUNTRY_CODE=es
COOKIDOO_LANGUAGE=es-ES
COOKIDOO_URL=https://cookidoo.es/foundation/es-ES
