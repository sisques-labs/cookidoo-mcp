# ---------------------------------------------------------------------------
# Cookidoo MCP server configuration
# Copy this file to `.env` and fill in your Cookidoo credentials.
# ---------------------------------------------------------------------------

# HTTP port the MCP server listens on (optional, defaults to 3000).
PORT=3000

# Cookidoo account credentials (required).
COOKIDOO_EMAIL=your@email.com
COOKIDOO_PASSWORD=your-password

# Localization (optional). Defaults to Swiss Cookidoo / German, matching the
# upstream library. Override all three together to target another market.
# Examples:
#   ch / de-CH / https://cookidoo.ch/foundation/de-CH
#   es / es    / https://cookidoo.es/foundation/es
#   gb / en-GB / https://cookidoo.co.uk/foundation/en-GB
COOKIDOO_COUNTRY_CODE=ch
COOKIDOO_LANGUAGE=de-CH
COOKIDOO_URL=https://cookidoo.ch/foundation/de-CH
